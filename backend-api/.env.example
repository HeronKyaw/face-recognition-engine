# =============================================================================
# Face Verification API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The API reads these variables at startup via pydantic-settings.
# Environment variables take precedence over .env values.
# =============================================================================

# -------------------- MySQL Database --------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=face_recognition_user
MYSQL_PASSWORD=F@ceRecognition4PI
MYSQL_DATABASE=face_recognition_db
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# -------------------- ChromaDB Vector Database --------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=face_embeddings
CHROMA_DISTANCE_THRESHOLD=0.5

# -------------------- Face Recognition Model --------------------
MODEL_PATH=models/sface.onnx
VERIFICATION_THRESHOLD=0.3

# -------------------- API Server --------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# -------------------- Image Enhancement --------------------
# Enable adaptive histogram equalization for low-light face images
ENABLE_LOWLIGHT_ENHANCEMENT=true
# Mean luminance threshold below which CLAHE is applied (0-255)
LOWLIGHT_LUMINANCE_THRESHOLD=50
# CLAHE clip limit (higher = more contrast)
CLAHE_CLIP_LIMIT=2.0
# CLAHE tile grid size (e.g. 8 = 8x8 tiles)
CLAHE_GRID_SIZE=8
# Apply unsharp mask after enhancement
ENHANCEMENT_SHARPEN=false

# -------------------- MediaPipe --------------------
# Face detection confidence threshold (default 0.5)
MEDIAPIPE_DETECTION_CONFIDENCE=0.5

# -------------------- Image Quality Checks (Enrollment) --------------------
# Minimum blur score (Laplacian variance / 100) to pass quality check
QUALITY_BLUR_THRESHOLD=0.15
# Minimum face bounding box dimension in pixels
QUALITY_MIN_FACE_SIZE=80
# Maximum head yaw angle in degrees
QUALITY_MAX_YAW=30.0
# Minimum mean luminance (0-255) to pass brightness check
QUALITY_BRIGHTNESS_MIN=30
# Maximum mean luminance (0-255) to pass brightness check
QUALITY_BRIGHTNESS_MAX=230

# -------------------- Enrollment Session (Two-Step) --------------------
# TTL for enrollment session tokens in seconds
ENROLL_SESSION_TTL_SECONDS=300

# -------------------- General --------------------
DEBUG=false
